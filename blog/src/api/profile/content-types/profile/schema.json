{
  "kind": "collectionType",
  "collectionName": "profiles",
  "info": {
    "singularName": "profile",
    "pluralName": "profiles",
    "displayName": "Profile "
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "full_name": {
      "type": "string"
    },
    "headline": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "about_me": {
      "type": "text"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "location": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "github_url": {
      "type": "string"
    },
    "linkedin_url": {
      "type": "string"
    },
    "facebook_url": {
      "type": "string"
    },
    "website_url": {
      "type": "string"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "profile"
    }
  }
}
